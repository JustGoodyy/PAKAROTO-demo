<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane styleClass="page-bg" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controller.MainLayoutController">

    <left>
        <VBox prefWidth="220" styleClass="sidebar" BorderPane.alignment="TOP_LEFT">

            <VBox alignment="CENTER" prefWidth="220" spacing="10" styleClass="sidebar-brand">
                <padding>
                    <Insets bottom="15" left="15" right="15" top="25" />
                </padding>
                <children>
                    <ImageView fx:id="imgLogo" fitHeight="90.0" fitWidth="160.0" preserveRatio="true">
                        <image>
                            <Image url="@../image/PAKAROTO.png" />
                        </image>
                    </ImageView>
                    <Label styleClass="sidebar-brand-sub" text="WORKSHOP CONSOLE" />
                </children>
            </VBox>

            <VBox styleClass="sidebar-user">
                <Label fx:id="lblActiveUser" styleClass="sidebar-user-label" text="—" />
            </VBox>

            <VBox fx:id="sidebarMenuBox" spacing="0" stylesheets="@../css/style.css">
                <padding><Insets bottom="10" top="10" /></padding>
                
                <Button onAction="#goToDashboard" styleClass="nav-button" text="Dashboard">
                    <graphic>
                        <ImageView fitHeight="18" fitWidth="18" preserveRatio="true">
                            <image>
                                <Image url="@../image/Dashboard.png" />
                            </image>
                        </ImageView>
                    </graphic>
                </Button>
                
                <Button onAction="#goToInventory" styleClass="nav-button" text="Inventaris Spare Part">
                    <graphic>
                        <ImageView fitHeight="18" fitWidth="18" preserveRatio="true">
                            <image>
                                <Image url="@../image/Inventaris.png" />
                            </image>
                        </ImageView>
                    </graphic>
                </Button>
                
                <Button onAction="#goToCashier" styleClass="nav-button" text="Transaksi Kas">
                    <graphic>
                        <ImageView fitHeight="18" fitWidth="18" preserveRatio="true">
                            <image>
                                <Image url="@../image/Tranksaksi.png" />
                            </image>
                        </ImageView>
                    </graphic>
                </Button>
                
                <Button onAction="#goToReport" styleClass="nav-button" text="Laporan Keuangan">
                    <graphic>
                        <ImageView fitHeight="18" fitWidth="18" preserveRatio="true">
                            <image>
                                <Image url="@../image/Laporan.png" />
                            </image>
                        </ImageView>
                    </graphic>
                </Button>
            </VBox>

            <Region VBox.vgrow="ALWAYS" />

            <Button fx:id="btnLogout" onAction="#handleLogout" styleClass="logout-button" text="Keluar">
            </Button>
        </VBox>
    </left>

    <center>
        <StackPane fx:id="contentArea" styleClass="content-area" BorderPane.alignment="CENTER" />
    </center>
</BorderPane>
