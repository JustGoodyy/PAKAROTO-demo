<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<ScrollPane fitToWidth="true" styleClass="scroll-pane" stylesheets="@../css/style.css" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controller.DashboardController">
    <VBox styleClass="page-bg">
       <children>
          
          <VBox spacing="4" style="-fx-background-color: -steel-dark; -fx-border-color: transparent transparent #2c3f4e transparent; -fx-border-width: 0 0 1px 0;">
             <padding>
                <Insets bottom="24" left="32" right="32" top="28" />
             </padding>
             <children>
                 <Label styleClass="h1" text="Dashboard" style="-fx-text-fill: #FFFFFF;" />
                 <Label styleClass="body-text" text="Ringkasan operasional bengkel hari ini." style="-fx-text-fill: rgba(255, 255, 255, 0.7);" />
             </children>
          </VBox>

          <VBox spacing="24">
             <padding>
                <Insets bottom="28" left="32" right="32" top="24" />
             </padding>
             <children>
                
                <HBox spacing="18">
                    <VBox spacing="8" styleClass="stat-card, stat-card-in" HBox.hgrow="ALWAYS">
                        <Label styleClass="stat-label" text="KAS MASUK HARI INI" />
                        <Label fx:id="lblCashInToday" styleClass="stat-value-in" text="Rp 0" />
                    </VBox>
                    <VBox spacing="8" styleClass="stat-card, stat-card-out" HBox.hgrow="ALWAYS">
                        <Label styleClass="stat-label" text="KAS KELUAR HARI INI" />
                        <Label fx:id="lblCashOutToday" styleClass="stat-value-out" text="Rp 0" />
                    </VBox>
                </HBox>
        
                <HBox spacing="18">
                    <VBox spacing="12" styleClass="panel" HBox.hgrow="ALWAYS">
                        <Label styleClass="h2" text="Peringatan Stok Menipis" />
                        <TableView fx:id="tableLowStock" prefHeight="260" VBox.vgrow="ALWAYS">
                            <columns>
                                <TableColumn fx:id="colLowStockNama" prefWidth="220" text="Nama Part" />
                                <TableColumn fx:id="colLowStockJumlah" prefWidth="100" text="Stok" />
                            </columns>
                            <columnResizePolicy><TableView fx:constant="CONSTRAINED_RESIZE_POLICY" /></columnResizePolicy>
                        </TableView>
                    </VBox>
        
                    <VBox spacing="12" styleClass="panel" HBox.hgrow="ALWAYS">
                        <Label styleClass="h2" text="Transaksi Terbaru" />
                        <TableView fx:id="tableRecent" prefHeight="260" VBox.vgrow="ALWAYS">
                            <columns>
                                <TableColumn fx:id="colRecentId" prefWidth="120" text="No. Nota" />
                                <TableColumn fx:id="colRecentCustomer" prefWidth="150" text="Customer" />
                                <TableColumn fx:id="colRecentTotal" prefWidth="120" text="Total" />
                            </columns>
                            <columnResizePolicy><TableView fx:constant="CONSTRAINED_RESIZE_POLICY" /></columnResizePolicy>
                        </TableView>
                    </VBox>
                </HBox>
                
                <Region prefHeight="4" />
             </children>
          </VBox>
          
       </children>
    </VBox>
</ScrollPane>