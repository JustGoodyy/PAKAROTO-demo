<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.String?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<ScrollPane fitToWidth="true" styleClass="scroll-pane" stylesheets="@../css/style.css" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controller.InventoryController">
    <VBox styleClass="page-bg">
       <children>
          
          <HBox alignment="CENTER_LEFT" spacing="16" style="-fx-background-color: -steel-dark; -fx-border-color: transparent transparent #2c3f4e transparent; -fx-border-width: 0 0 1px 0;">
             <padding>
                <Insets bottom="24" left="32" right="32" top="28" />
             </padding>
             <children>
                <VBox spacing="2" HBox.hgrow="ALWAYS">
                   <children>
                      <Label styleClass="h1" text="Inventaris Spare Part" style="-fx-text-fill: #FFFFFF;" />
                      <Label styleClass="body-text" text="Kelola katalog, stok, dan harga spare part." style="-fx-text-fill: rgba(255, 255, 255, 0.7);" />
                   </children>
                </VBox>
                <TextField fx:id="txtSearch" prefWidth="260" promptText="Cari kode atau nama part..." styleClass="search-bar" />
             </children>
          </HBox>

          <VBox spacing="20">
             <padding>
                <Insets bottom="28" left="32" right="32" top="24" />
             </padding>
             <children>
                 
                 <HBox spacing="20">
                     <VBox prefWidth="300" spacing="12" styleClass="panel">
                         <children>
                             <Label styleClass="h2" text="Detail Part" />
             
                             <VBox spacing="6">
                                 <children>
                                     <Label styleClass="field-label" text="KODE" />
                                     <TextField fx:id="txtKode" promptText="cth. SP-0001" />
                                 </children>
                             </VBox>
                             <VBox spacing="6">
                                 <children>
                                     <Label styleClass="field-label" text="NAMA PART" />
                                     <TextField fx:id="txtNama" promptText="Nama spare part" />
                                 </children>
                             </VBox>
                             <VBox spacing="6">
                                 <children>
                                     <Label styleClass="field-label" text="KATEGORI" />
                                     <ComboBox fx:id="cbKategori" maxWidth="Infinity" promptText="Pilih kategori" />
                                 </children>
                             </VBox>
                             <VBox spacing="6">
                                 <children>
                                     <Label styleClass="field-label" text="STOK" />
                                     <TextField fx:id="txtStok" promptText="0" />
                                 </children>
                             </VBox>
                             <VBox spacing="6">
                                 <children>
                                     <Label styleClass="field-label" text="HARGA JUAL" />
                                     <TextField fx:id="txtHargaJual" promptText="0" />
                                 </children>
                             </VBox>
                             <VBox spacing="6">
                                 <children>
                                     <Label styleClass="field-label" text="HARGA MODAL (opsional)" />
                                     <TextField fx:id="txtHargaModal" promptText="60% harga jual bila kosong" />
                                 </children>
                             </VBox>
             
                             <Label fx:id="lblFormStatus" styleClass="status-msg" wrapText="true" />
             
                             <HBox spacing="10">
                                 <children>
                                     <Button fx:id="btnAdd" maxWidth="Infinity" onAction="#handleAdd" styleClass="btn-primary" text="Tambah" HBox.hgrow="ALWAYS" />
                                     <Button fx:id="btnUpdate" maxWidth="Infinity" onAction="#handleUpdate" styleClass="btn-secondary" text="Perbarui" HBox.hgrow="ALWAYS" />
                                 </children>
                             </HBox>
                             <HBox spacing="10">
                                 <children>
                                     <Button fx:id="btnDelete" maxWidth="Infinity" onAction="#handleDelete" styleClass="btn-danger" text="Hapus" HBox.hgrow="ALWAYS" />
                                     <Button maxWidth="Infinity" onAction="#handleClear" styleClass="btn-ghost" text="Bersihkan Form" HBox.hgrow="ALWAYS" />
                                 </children>
                             </HBox>
                         </children>
                     </VBox>
             
                     <VBox spacing="12" styleClass="panel" HBox.hgrow="ALWAYS">
                         <children>
                             <Label styleClass="h2" text="Katalog Spare Part" />
                             <TableView fx:id="tableSparepart" prefHeight="480" VBox.vgrow="ALWAYS">
                                 <columns>
                                     <TableColumn fx:id="colKode" prefWidth="90" text="Kode" />
                                     <TableColumn fx:id="colNama" prefWidth="200" text="Nama" />
                                     <TableColumn fx:id="colKategori" prefWidth="140" text="Kategori" />
                                     <TableColumn fx:id="colStok" prefWidth="80" text="Stok" />
                                     <TableColumn fx:id="colHarga" prefWidth="120" text="Harga Jual" />
                                 </columns>
                                 <columnResizePolicy><TableView fx:constant="CONSTRAINED_RESIZE_POLICY" /></columnResizePolicy>
                             </TableView>
                         </children>
                     </VBox>
                 </HBox>
                 
                 <Region prefHeight="4" />
             </children>
          </VBox>

       </children>
    </VBox>
</ScrollPane>