<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<ScrollPane fitToWidth="true" styleClass="scroll-pane"
            xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml"
            fx:controller="controller.InventoryController">
    <VBox styleClass="page-bg" spacing="20">
        <padding><Insets top="28" right="32" bottom="28" left="32"/></padding>

        <HBox alignment="CENTER_LEFT" spacing="16">
            <VBox spacing="2" HBox.hgrow="ALWAYS">
                <Label text="Inventaris Spare Part" styleClass="h1"/>
                <Label text="Kelola katalog, stok, dan harga spare part." styleClass="body-text"/>
            </VBox>
            <TextField fx:id="txtSearch" promptText="Cari kode atau nama part..." prefWidth="260"/>
        </HBox>

        <HBox spacing="20">
            <!-- Form -->
            <VBox styleClass="panel" spacing="12" prefWidth="300">
                <Label text="Detail Part" styleClass="h2"/>

                <VBox spacing="6">
                    <Label text="KODE" styleClass="field-label"/>
                    <TextField fx:id="txtKode" promptText="cth. SP-0001"/>
                </VBox>
                <VBox spacing="6">
                    <Label text="NAMA PART" styleClass="field-label"/>
                    <TextField fx:id="txtNama" promptText="Nama spare part"/>
                </VBox>
                <VBox spacing="6">
                    <Label text="KATEGORI" styleClass="field-label"/>
                    <ComboBox fx:id="cbKategori" promptText="Pilih kategori" maxWidth="Infinity"/>
                </VBox>
                <VBox spacing="6">
                    <Label text="STOK" styleClass="field-label"/>
                    <TextField fx:id="txtStok" promptText="0"/>
                </VBox>
                <VBox spacing="6">
                    <Label text="HARGA JUAL" styleClass="field-label"/>
                    <TextField fx:id="txtHargaJual" promptText="0"/>
                </VBox>
                <VBox spacing="6">
                    <Label text="HARGA MODAL (opsional)" styleClass="field-label"/>
                    <TextField fx:id="txtHargaModal" promptText="60% harga jual bila kosong"/>
                </VBox>

                <Label fx:id="lblFormStatus" styleClass="status-msg" wrapText="true"/>

                <HBox spacing="10">
                    <Button fx:id="btnAdd" text="Tambah" styleClass="btn-primary" onAction="#handleAdd" HBox.hgrow="ALWAYS" maxWidth="Infinity"/>
                    <Button fx:id="btnUpdate" text="Perbarui" styleClass="btn-secondary" onAction="#handleUpdate" HBox.hgrow="ALWAYS" maxWidth="Infinity"/>
                </HBox>
                <HBox spacing="10">
                    <Button fx:id="btnDelete" text="Hapus" styleClass="btn-danger" onAction="#handleDelete" HBox.hgrow="ALWAYS" maxWidth="Infinity"/>
                    <Button text="Bersihkan Form" styleClass="btn-ghost" onAction="#handleClear" HBox.hgrow="ALWAYS" maxWidth="Infinity"/>
                </HBox>
            </VBox>

            <!-- Table -->
            <VBox styleClass="panel" spacing="12" HBox.hgrow="ALWAYS">
                <Label text="Katalog Spare Part" styleClass="h2"/>
                <TableView fx:id="tableSparepart" VBox.vgrow="ALWAYS" prefHeight="480">
                    <columns>
                        <TableColumn fx:id="colKode" text="Kode" prefWidth="90"/>
                        <TableColumn fx:id="colNama" text="Nama" prefWidth="200"/>
                        <TableColumn fx:id="colKategori" text="Kategori" prefWidth="140"/>
                        <TableColumn fx:id="colStok" text="Stok" prefWidth="80"/>
                        <TableColumn fx:id="colHarga" text="Harga Jual" prefWidth="120"/>
                    </columns>
                    <columnResizePolicy><TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/></columnResizePolicy>
                </TableView>
            </VBox>
        </HBox>
        <Region prefHeight="4"/>
    </VBox>
</ScrollPane>
